[
  {
    "id": "RULE-ARQ-001",
    "description": "Penaliza arquitetura por violações de dependência",
    "when": {
      "metric": "violationDensity",
      "operator": "gt",
      "value": 0
    },
    "then": {
      "type": "linear",
      "metric": "totalViolations",
      "factor": 10,
      "limit": 100
    },
    "impacts": ["ARQ"]
  },
